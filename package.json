{
  "name": "proofclip",
  "version": "0.1.0",
  "private": true,
  "description": "Testimonial wall + social-proof content generator",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init:local": "wrangler d1 execute proofclip --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute proofclip --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.95.0"
  }
}
